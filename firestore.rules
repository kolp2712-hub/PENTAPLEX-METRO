rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: site_content
    // Document ID: config, assets_hero, assets_gallery, assets_location, assets_floorplans, notices
    //
    // Collection: inquiries
    // Fields: name, phone, content, createdAt, status
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "kolp2712@gmail.com");
    }

    // Site Content: Only Admin can write, anyone can read (for the public site)
    match /site_content/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Inquiries: Anyone can create, only Admin can read/update/delete
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
