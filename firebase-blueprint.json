{
  "entities": {
    "SiteContent": {
      "title": "Site Content",
      "description": "Stores all website content including text and base64 images",
      "type": "object",
      "properties": {
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "themeColor": { "type": "string" },
        "fontFamily": { "type": "string" },
        "title": { "type": "string" },
        "logoIcon": { "type": "string" },
        "representativePhone": { "type": "string" },
        "heroSlogan": { "type": "string" },
        "heroDescription": { "type": "string" },
        "heroButtonText": { "type": "string" },
        "heroImages": { "type": "array", "items": { "type": "string" } },
        "highlights": { "type": "array" },
        "galleryImages": { "type": "array", "items": { "type": "string" } },
        "locationMaps": { "type": "array", "items": { "type": "string" } },
        "floorPlans": { "type": "array" },
        "notices": { "type": "array" }
      }
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Customer consultation requests",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "contacted", "completed"] }
      },
      "required": ["name", "phone", "createdAt"]
    }
  },
  "firestore": {
    "/site_content/{documentId}": {
      "schema": "SiteContent",
      "description": "Split documents for site configuration and assets"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Customer inquiries"
    }
  }
}
